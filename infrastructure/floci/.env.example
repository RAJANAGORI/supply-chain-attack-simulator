# SCAS Floci emulator — copy to .env (floci-setup.sh does this automatically)
FLOCI_PORT=4566
FLOCI_DEFAULT_REGION=us-east-1
FLOCI_STORAGE_MODE=hybrid
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Set to 1 after setup when using --image (published container, no source build)
FLOCI_USE_IMAGE=0

# Published image tag when FLOCI_USE_IMAGE=1
FLOCI_IMAGE=floci/floci:latest-compat
