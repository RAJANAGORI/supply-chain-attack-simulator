{
  "index_patterns": ["scas-rules"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "scenario_id": { "type": "keyword" },
        "scenario_name": { "type": "keyword" },
        "title": { "type": "text" },
        "iocs": { "type": "text" },
        "sigma": { "type": "text" },
        "yara": { "type": "text" },
        "edr_expectations": { "type": "text" },
        "sample_logs": { "type": "object", "enabled": true },
        "mitre": {
          "properties": {
            "tactic": { "type": "keyword" },
            "technique": { "type": "keyword" }
          }
        },
        "source_file": { "type": "keyword" },
        "ingested_at": { "type": "date" },
        "raw_markdown": { "type": "text" }
      }
    }
  },
  "priority": 100,
  "_meta": {
    "description": "Detection runbooks parsed from scenario DETECT.md files"
  }
}
