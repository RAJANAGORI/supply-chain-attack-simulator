{
  "name": "devcorp-workspace",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "devcorp-workspace",
      "version": "1.0.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@devcorp/api": {
      "resolved": "packages/api",
      "link": true
    },
    "node_modules/@devcorp/auth": {
      "resolved": "packages/auth",
      "link": true
    },
    "node_modules/@devcorp/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "packages/api": {
      "name": "@devcorp/api",
      "version": "1.0.0",
      "license": "MIT",
      "dependencies": {
        "@devcorp/utils": "file:../utils"
      }
    },
    "packages/auth": {
      "name": "@devcorp/auth",
      "version": "1.0.0",
      "license": "MIT",
      "dependencies": {
        "@devcorp/utils": "file:../utils"
      }
    },
    "packages/utils": {
      "name": "@devcorp/utils",
      "version": "1.0.0",
      "license": "MIT"
    }
  }
}
